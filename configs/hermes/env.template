# Model/provider secrets belong here locally, not in git.

# Example model provider
OPENROUTER_API_KEY=

# Optional local inference sidecar for low-risk requests.
# Approved topology: Hermes in WSL2, Ollama on Windows.
# If 127.0.0.1 is not reachable from WSL2 on this machine, replace it with the Windows host address visible from WSL2.
OLLAMA_BASE_URL=http://127.0.0.1:11434
LOCAL_FAST_MODEL=gemma4:26b

# Keep at least one live cloud provider for high-risk teaching tasks
CLOUD_PRIMARY_PROVIDER=openrouter

# Feishu / Lark
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Optional Feishu settings
FEISHU_ALLOWED_USERS=
FEISHU_HOME_CHANNEL=
FEISHU_DOMAIN=feishu
FEISHU_CONNECTION_MODE=websocket
